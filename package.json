{
  "name": "anhedral",
  "version": "0.4.1",
  "description": "Generate a complete, readable TypeScript product stack with Next.js, Expo, Fastify, Neon, Drizzle, Clerk, R2, Electron updates, WXT, and Vercel.",
  "type": "module",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    }
  },
  "types": "./dist/index.d.ts",
  "sideEffects": false,
  "bin": {
    "anhedral": "bin/anhedral.js"
  },
  "files": [
    "bin",
    "dist",
    "docs/conventions.md",
    "assets/anhedral-cli-init.svg",
    "assets/images/svg/ably-symbol-color.svg",
    "assets/images/svg/logo-white-subtract.svg",
    "docs/master-stack-map.md",
    "docs/output-tree-contract.md",
    "docs/references",
    "scripts/render-master-stack-map.mjs",
    "templates",
    "SKILL.md",
    "CHANGELOG.md",
    "CONTRIBUTING.md",
    "LICENSE",
    "README.md",
    "SECURITY.md",
    "anhedral.svg",
    "favicon.ico"
  ],
  "homepage": "https://github.com/anhedral/anhedral-init#readme",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/anhedral/anhedral-init.git"
  },
  "bugs": {
    "url": "https://github.com/anhedral/anhedral-init/issues"
  },
  "author": "Anhedral, Inc.",
  "publishConfig": {
    "access": "public"
  },
  "engines": {
    "node": "^20.19.0 || >=22.12.0"
  },
  "scripts": {
    "scaffold": "node dist/bin.js init",
    "clean": "node scripts/clean.mjs",
    "build": "pnpm clean && tsc",
    "prepare": "pnpm build",
    "typecheck": "tsc --noEmit",
    "check:hygiene": "node scripts/check-source-hygiene.mjs",
    "check:security": "node scripts/check-security-policy.mjs",
    "check:release-policy": "node scripts/check-release-policy.mjs",
    "check:release-secrets": "node scripts/check-release-secrets.mjs",
    "lint": "pnpm typecheck && pnpm check:hygiene && pnpm check:release-policy",
    "audit:osv": "pnpm build && node scripts/audit-osv.mjs --generator",
    "test": "pnpm test:cli",
    "test:coverage": "pnpm build && c8 --all --include='dist/**/*.js' --reporter=text --reporter=json-summary --check-coverage --lines 84 --statements 84 --functions 84 --branches 80 node tests/test-cli.js",
    "pretest": "pnpm build",
    "prepublishOnly": "pnpm test:all",
    "test:cli": "node tests/test-cli.js",
    "test:cli:validation": "node tests/test-cli-validation.js",
    "test:deps": "pnpm build && node tests/test-dependency-manifest.js",
    "test:vercel-schema": "pnpm build && node tests/test-vercel-services-schema.js",
    "test:pack": "pnpm build && node tests/test-packed-cli.js",
    "test:pack:exact": "node tests/test-packed-cli.js release-artifact/metadata.json",
    "test:packlist": "pnpm build && node tests/test-packlist.js",
    "test:release-tooling": "node tests/test-release-tooling.js",
    "test:topologies": "pnpm build && node tests/test-module-topology-invariants.js",
    "test:templates": "pnpm build && node tests/test-template-source.js",
    "pretest:e2e": "pnpm build",
    "test:e2e": "node tests/test-e2e-public-stacks.js",
    "pretest:e2e:latest": "pnpm build",
    "test:e2e:latest": "node tests/test-e2e-public-stacks.js --toolchain latest",
    "test:acceptance:desktop": "pnpm build && node tests/test-runtime-acceptance.js desktop",
    "test:acceptance:extension": "pnpm build && node tests/test-runtime-acceptance.js extension",
    "test:acceptance:mobile": "pnpm build && node tests/test-runtime-acceptance.js mobile",
    "test:all": "pnpm lint && pnpm check:security && pnpm audit:osv && pnpm test:coverage && pnpm test:deps && pnpm test:templates && pnpm test:vercel-schema && pnpm test:pack && pnpm test:packlist && pnpm test:e2e",
    "release:check": "pnpm check:release-policy && pnpm test:all && npm pack --dry-run --ignore-scripts",
    "release:pack": "pnpm build && node scripts/create-release-artifact.mjs && node scripts/check-release-secrets.mjs release-artifact/metadata.json",
    "release:artifact:verify": "node scripts/verify-release-artifact.mjs release-artifact/metadata.json && node scripts/check-release-secrets.mjs release-artifact/metadata.json",
    "release:artifact:smoke": "node tests/test-packed-cli.js release-artifact/metadata.json",
    "demo:refresh": "pnpm build && node tests/refresh-demo.js",
    "docs:stack-map": "node scripts/render-master-stack-map.mjs"
  },
  "keywords": [
    "cli",
    "scaffold",
    "typescript",
    "nextjs",
    "fastify",
    "expo",
    "electron",
    "clerk",
    "drizzle",
    "neondb",
    "revenuecat",
    "wxt",
    "vercel"
  ],
  "license": "Apache-2.0",
  "packageManager": "pnpm@10.34.5",
  "devDependencies": {
    "@types/node": "20.19.43",
    "c8": "11.0.0",
    "simple-icons": "16.27.0",
    "typescript": "5.9.3"
  }
}
