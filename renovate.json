{
  "$schema": "https://docs.renovatebot.com/renovate-schema.json",
  "extends": [
    "config:recommended"
  ],
  "timezone": "America/Los_Angeles",
  "labels": [
    "dependencies"
  ],
  "dependencyDashboard": true,
  "rangeStrategy": "bump",
  "prHourlyLimit": 2,
  "prConcurrentLimit": 6,
  "schedule": [
    "before 6am on monday"
  ],
  "lockFileMaintenance": {
    "enabled": true
  },
  "packageRules": [
    {
      "matchManagers": [
        "github-actions"
      ],
      "groupName": "github-actions",
      "addLabels": [
        "github-actions"
      ],
      "matchUpdateTypes": [
        "patch",
        "minor",
        "digest"
      ],
      "automerge": true
    },
    {
      "matchManagers": [
        "npm"
      ],
      "matchDepTypes": [
        "devDependencies"
      ],
      "matchUpdateTypes": [
        "patch",
        "minor"
      ],
      "groupName": "devDependencies (non-major)",
      "automerge": true
    },
    {
      "matchManagers": [
        "custom.regex"
      ],
      "groupName": "toolchain pins",
      "addLabels": [
        "toolchain"
      ],
      "automerge": false
    },
    {
      "matchUpdateTypes": [
        "major"
      ],
      "addLabels": [
        "major"
      ]
    }
  ],
  "customManagers": [
    {
      "customType": "regex",
      "description": "Pinned verified generated dependency versions",
      "fileMatch": [
        "^src/dependencies\\.ts$"
      ],
      "matchStrings": [
        "// renovate: datasource=(?<datasource>\\S+) depName=(?<depName>\\S+)\\s+(?:['\\\"]?[^:'\\\"]+['\\\"]?): '(?<currentValue>[^']+)'"
      ]
    }
  ]
}
